# 🦅 HawkEye Ultimate — Environment Variables
# Copy this to .env and fill in your values

# ── Telegram ───────────────────────────────────────────────────────
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ── GetContact (main phone ID source) ──────────────────────────────
# Extract from the GetContact Android app — see SETUP.md Step 4
GETCONTACT_TOKEN=your_getcontact_token_here
GETCONTACT_FINAL_KEY=your_getcontact_final_key_here

# ── Truecaller (secondary phone ID source) ─────────────────────────
# Extract installationId from Truecaller app — see SETUP.md Step 5
TRUECALLER_INSTALLATION_ID=your_truecaller_installation_id_here
TRUECALLER_COUNTRY_CODE=IL

# ── NumVerify (carrier/country info, free) ─────────────────────────
# Get free key at https://numverify.com
NUMVERIFY_API_KEY=your_numverify_key_here

# ── Data files (paths to local databases) ──────────────────────────
FACEBOOK_CSV_PATH=data/Facebook.csv
LAWYERS_XLSX_PATH=data/lawyers.xlsx
